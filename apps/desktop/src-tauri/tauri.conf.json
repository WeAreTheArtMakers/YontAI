{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YontAI",
  "version": "0.1.0",
  "identifier": "com.yontai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YontAI",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../../start-backend.sh",
      "../../../apps/backend/**/*"
    ]
  }
}
